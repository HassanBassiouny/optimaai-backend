# ── Odoo integration ──────────────────────────────────────
# Where Odoo is reachable.
#   - From inside docker-compose:  http://odoo:8069  (use the service name)
#   - From your host machine:       http://localhost:8069
ODOO_URL=http://localhost:8069

# Odoo database name. Visible in Odoo's login dropdown if you have several,
# or in the URL after creating the DB the first time. Case-sensitive.
ODOO_DB=optimaai_db

# Credentials. Use ODOO_API_KEY in production (Odoo → Preferences →
# Account Security → New API Key) and leave ODOO_PASSWORD empty.
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_API_KEY=441a49dcc731d18a92d0e26578840995ad15a061


# User id (in OptimaAi's `users` table) under which scheduled syncs are
# recorded. Defaults to 1 (the first registered user). Create a dedicated
# service account and put its id here for production.
ODOO_SYNC_USER_ID=1